# Notion API Configuration
NOTION_API_TOKEN=your_notion_integration_token_here
EXPENSE_TABLE_DATABASE_ID=your_expense_table_database_id_here
SPLIT_DETAILS_DATABASE_ID=your_split_details_database_id_here

# Balances Page — the single row in the Balances table that tracks running totals
# Get this by opening the Balances page in Notion and copying the page ID from the URL
BALANCES_PAGE_ID=your_balances_page_id_here

# User Configuration
# YOUR_NAME / PARTNER_NAME are display names shown in the UI preview
# YOUR_USER_ID / PARTNER_USER_ID are Notion user IDs used to select the person object in Notion tables
# YOUR_EMOJI / PARTNER_EMOJI are emojis that will appear as icons on split entries in Notion
# The system will automatically resolve user IDs to display names in the final preview
YOUR_NAME=Jon Doe
PARTNER_NAME=Jane Doe
YOUR_EMOJI=👱🏼‍♂️
PARTNER_EMOJI=👩🏾

YOUR_USER_ID=your_notion_user_id_here
PARTNER_USER_ID=partner_notion_user_id_here

# File Paths (relative to project root)
INPUT_FOLDER=receipts/input
PROCESSED_FOLDER=receipts/processed

# Split Configuration
DEFAULT_SPLIT_PERCENTAGE=50.0

# Test Environment Configuration (for E2E tests)
# IMPORTANT: Use separate test databases, NEVER production databases!
NOTION_TEST_TOKEN=your_test_integration_token_here
NOTION_TEST_EXPENSE_DB_ID=your_test_expense_database_id_here
NOTION_TEST_SPLIT_DB_ID=your_test_split_database_id_here